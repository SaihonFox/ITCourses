<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/em_dark"
	tools:context=".ui.LoginFragment">
	
	
	<TextView
		android:id="@+id/title"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_marginStart="16dp"
		android:layout_marginTop="100dp"
		android:layout_marginEnd="16dp"
		android:fontFamily="@font/roboto"
		android:text="Вход"
		android:textColor="@color/em_white"
		android:textSize="28sp"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent" />
	
	<LinearLayout
		android:id="@+id/linearLayout"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_marginStart="16dp"
		android:layout_marginTop="28dp"
		android:layout_marginEnd="16dp"
		android:orientation="vertical"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@+id/title">
		
		<androidx.constraintlayout.widget.ConstraintLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content">
			
			<TextView
				android:id="@+id/text_email"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:fontFamily="@font/roboto_medium"
				android:lineSpacingExtra="18sp"
				android:lineSpacingMultiplier="0"
				android:text="Email"
				android:textColor="@color/em_white"
				android:textSize="16sp"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintTop_toTopOf="parent" />
			
			<EditText
				android:id="@+id/email"
				android:layout_width="0dp"
				android:layout_height="40dp"
				android:layout_marginTop="8dp"
				android:background="@drawable/input_shape"
				android:ems="10"
				android:hint="example@gmail.com"
				android:inputType="textEmailAddress"
				android:lineSpacingExtra="20sp"
				android:paddingHorizontal="16dp"
				android:textColor="@android:color/white"
				android:textColorHint="@color/em_white"
				android:textSize="14sp"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintTop_toBottomOf="@id/text_email" />
		</androidx.constraintlayout.widget.ConstraintLayout>
		
		<Space
			android:layout_width="match_parent"
			android:layout_height="16dp" />
		
		<androidx.constraintlayout.widget.ConstraintLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content">
			
			<TextView
				android:id="@+id/text_password"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:fontFamily="@font/roboto_medium"
				android:lineSpacingExtra="18sp"
				android:lineSpacingMultiplier="0"
				android:text="Пароль"
				android:textColor="@color/em_white"
				android:textSize="16sp"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintTop_toTopOf="parent" />
			
			<EditText
				android:id="@+id/password"
				android:layout_width="match_parent"
				android:layout_height="40dp"
				android:layout_marginTop="8dp"
				android:background="@drawable/input_shape"
				android:ems="10"
				android:hint="Введите пароль"
				android:inputType="textPassword"
				android:lineSpacingExtra="20sp"
				android:paddingHorizontal="16dp"
				android:textColor="@android:color/white"
				android:textColorHint="@color/em_white"
				android:textSize="14sp"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintTop_toBottomOf="@+id/text_password" />
		</androidx.constraintlayout.widget.ConstraintLayout>
	
	</LinearLayout>
	
	<Button
		android:id="@+id/enter_btn"
		android:layout_width="0dp"
		android:layout_marginStart="16dp"
		android:layout_marginTop="24dp"
		android:layout_marginEnd="16dp"
		style="@style/PrimaryButtonStyle"
		android:text="Вход"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@+id/linearLayout" />
	
	<TextView
		android:id="@+id/text_noacc"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginStart="96dp"
		android:layout_marginTop="16dp"
		android:layout_marginEnd="97dp"
		android:fontFamily="@font/roboto_semibold"
		android:lineSpacingExtra="15dp"
		android:lineSpacingMultiplier="0"
		android:text="@string/text_noacc"
		android:textColor="@color/em_white"
		android:textSize="12sp"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@+id/enter_btn" />
	
	<TextView
		android:id="@+id/text_forgetpwd"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginTop="8dp"
		android:fontFamily="@font/roboto_semibold"
		android:lineSpacingExtra="15dp"
		android:lineSpacingMultiplier="0"
		android:text="Забыл пароль"
		android:textColor="#12B956"
		android:textSize="12sp"
		app:layout_constraintEnd_toEndOf="@+id/text_noacc"
		app:layout_constraintStart_toStartOf="@+id/text_noacc"
		app:layout_constraintTop_toBottomOf="@+id/text_noacc" />
	
	<androidx.cardview.widget.CardView
		android:id="@+id/cardView"
		android:layout_width="match_parent"
		android:layout_height="1dp"
		android:layout_marginStart="16dp"
		android:layout_marginTop="32dp"
		android:layout_marginEnd="16dp"
		style="@style/Divider"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@+id/text_forgetpwd" />
	
	<LinearLayout
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_marginStart="16dp"
		android:layout_marginTop="32dp"
		android:layout_marginEnd="16dp"
		android:orientation="horizontal"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@+id/cardView">
		
		<ImageButton
			android:id="@+id/vk_btn"
			android:background="@drawable/vk_button_layout"
			android:layout_width="wrap_content"
			android:layout_height="40dp"
			android:layout_weight="1"
			android:src="@drawable/vk_logo"
			android:contentDescription="vk logo" />
		
		<Space
			android:layout_width="16dp"
			android:layout_height="match_parent" />
		
		<ImageButton
			android:id="@+id/ok_btn"
			android:background="@drawable/ok_button_layout"
			android:layout_width="wrap_content"
			android:layout_height="40dp"
			android:layout_weight="1"
			android:src="@drawable/ok_logo"
			android:contentDescription="ok logo" />
	</LinearLayout>
	
</androidx.constraintlayout.widget.ConstraintLayout>